<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - LNP Fashion Demon</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/Login.css">
</head>
<body class="d-flex flex-column min-vh-100">
<div class="logo-container">
    <div class="wave-animation"></div>
    <h1 class="brand-name">LNP</h1>
    <div class="brand-subtitle"><span class="red-text">FASHION DEMON</span></div>
</div>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <div class="d-flex w-100 justify-content-between align-items-center">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Home")">Главная</a></li>
                <li class="nav-item"><a class="nav-link" href="@Url.Action("About", "Home")">О нас</a></li>
                <li class="nav-item"><a class="nav-link" href="@Url.Action("Contact", "Home")">Контакты</a></li>
                <li class="nav-item"><a class="nav-link" href="@Url.Action("Catalog", "Product")">Каталог</a></li>
                <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Cart")">Корзина</a></li>
                @if (!Request.IsAuthenticated)
                {
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Register", "Account")">Регистрация</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Login", "Account")">Вход</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Catalog", "Product")">Каталог</a></li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Product")">Продукт</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Category")">Категория</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("CheckOut", "Order")">Заказ</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Catalog", "Product")">Каталог</a></li>
                }
            </ul>

            @if (Request.IsAuthenticated)
            {
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Logout", "Account")">Выход</a>
                    </li>
                </ul>
            }
        </div>
    </div>
</nav>

<main class="container-fluid py-4 flex-grow-1">
    @RenderBody()
</main>

<footer class="bg-dark text-white text-center py-2">
    <p>© 2025 LNP Fashion Demon. Все права защищены.</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("scripts", required: false)
</body>
</html>