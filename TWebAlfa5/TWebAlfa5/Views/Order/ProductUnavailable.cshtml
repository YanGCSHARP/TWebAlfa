@* Views/Order/ProductUnavailable.cshtml *@
@{
    ViewBag.Title = "Товар недоступен";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="alert alert-danger text-center">
        <h2 class="mb-4">😞 Товар временно недоступен</h2>
        
        @if (TempData["ProductName"] != null)
        {
            <div class="card border-danger mb-3">
                <div class="card-body">
                    <h5 class="card-title">@TempData["ProductName"]</h5>
                    @if (TempData["AvailableQuantity"] != null)
                    {
                        <p class="mb-1">Доступно: @TempData["AvailableQuantity"] шт.</p>
                    }
                    @if (TempData["RequestedQuantity"] != null)
                    {
                        <p class="mb-0">Запрошено: @TempData["RequestedQuantity"] шт.</p>
                    }
                </div>
            </div>
        }
        
        <div class="mt-4">
            <a href="@Url.Action("Catalog", "Product")" class="btn btn-primary">
                <i class="fas fa-arrow-left"></i> Вернуться в каталог
            </a>
        </div>
    </div>
</div>