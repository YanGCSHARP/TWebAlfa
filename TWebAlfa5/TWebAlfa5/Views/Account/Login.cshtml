@model eUseControl.Domain.Models.Login
@{
    ViewBag.Title = "Вход";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-12">
        <div class="auth-container">
            <div class="auth-form active" id="login-form">
                <h3 class="text-center mb-3">Вход в аккаунт</h3>
                @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "auth-form" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="form-group mb-3">
                        <label for="Name" class="form-label">Логин:</label>
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control", id = "login-email", required = "required" })
                        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group mb-3">
                        <label for="Password" class="form-label">Пароль:</label>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", id = "login-password", required = "required" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group mb-3">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", id = "remember-me" })
                            <label for="RememberMe" class="form-check-label">Запомнить меня</label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-danger w-100">Войти</button>
                    <div class="form-footer text-center mt-2">
                        <a href="#" class="forgot-password">Забыли пароль?</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>