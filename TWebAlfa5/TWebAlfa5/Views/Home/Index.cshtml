@{
    ViewBag.Title = "Главная - LNP Fashion Demon";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-3">
    <main>
        <section class="hero">
            <div class="hero-content text-center">
                <span class="golden-text">Новая коллекция</span>
                <p>Откройте для себя уникальный стиль</p>
                <a href="@Url.Action("Catalog", "Product")" class="btn btn-danger">Смотреть коллекцию</a>
            </div>
        </section>

        <section class="features row justify-content-center g-4">
            <div class="col-lg-4 col-md-6 col-12">
                <div class="feature-card text-center">
                    <div class="feature-icon">🚚</div>
                    <h3>Быстрая доставка</h3>
                    <p>По всей Молдове за 1-3 дня</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 col-12">
                <div class="feature-card text-center">
                    <div class="feature-icon">💎</div>
                    <h3>Качество</h3>
                    <p>Премиальные материалы</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 col-12">
                <div class="feature-card text-center">
                    <div class="feature-icon">🔄</div>
                    <h3>Возврат</h3>
                    <p>30 дней на обмен и возврат</p>
                </div>
            </div>
        </section>

        <section class="new-arrivals">
            <h2 class="section-title text-center mb-3">Новинки</h2>
            <div class="product-slider row justify-content-center g-4">
                <div class="col-lg-6 col-md-6 col-12">
                    <div class="product-card featured text-center">
                        <h3>Стильная футболка</h3>
                        <p class="price">2999 ₽</p>
                        <a href="#" class="btn btn-danger">В корзину</a>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-12">
                    <div class="product-card featured text-center">
                        <h3>Модные джинсы</h3>
                        <p class="price">4999 ₽</p>
                        <a href="#" class="btn btn-danger">В корзину</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="categories">
            <h2 class="section-title text-center mb-3">Категории</h2>
            <div class="category-grid row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                <div class="col">
                    <a href="@Url.Action("Catalog", "Product", new { category = "men" })" class="category-card">
                        <div class="category-overlay-m text-center">
                            <div class="category-icon">👔</div>
                            <h3>Мужская одежда</h3>
                        </div>
                    </a>
                </div>
                <div class="col">
                    <a href="@Url.Action("Catalog", "Product", new { category = "women" })" class="category-card">
                        <div class="category-overlay-f text-center">
                            <div class="category-icon">👗</div>
                            <h3>Женская одежда</h3>
                        </div>
                    </a>
                </div>
                <div class="col">
                    <a href="@Url.Action("Catalog", "Product", new { category = "accessories" })" class="category-card">
                        <div class="category-overlay-a text-center">
                            <div class="category-icon">💍</div>
                            <h3>Аксессуары</h3>
                        </div>
                    </a>
                </div>
            </div>
        </section>
    </main>
</div>