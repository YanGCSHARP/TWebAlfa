@model object
@{
    ViewBag.Title = "О нас - LNP Fashion Demon";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Используем общий макет
}

<div class="container-fluid py-3">
    <section class="info-page">
        <section class="info-hero">
            <div class="info-hero-content">
                <span class="golden-text">Наша История</span>
                <p>С 2025 года мы создаем уникальную моду для уникальных людей</p>
            </div>
        </section>

        <section class="mission-section">
            <div class="mission-content">
                <h3 class="text-center mb-3">Наша Миссия</h3>
                <p>LNP Fashion Demon - это не просто бренд одежды. Это образ жизни, философия и стремление к совершенству в каждой детали.</p>
                <div class="mission-stats row justify-content-center g-4">
                    <div class="col-lg-4 col-md-6 col-12">
                        <div class="stat-item text-center">
                            <span class="stat-number">5000+</span>
                            <span class="stat-label">Довольных клиентов</span>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 col-12">
                        <div class="stat-item text-center">
                            <span class="stat-number">300+</span>
                            <span class="stat-label">Уникальных моделей</span>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 col-12">
                        <div class="stat-item text-center">
                            <span class="stat-number">15</span>
                            <span class="stat-label">Городов присутствия</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="values-section">
            <h3 class="text-center mb-3">Наши Ценности</h3>
            <div class="values-grid row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                <div class="col">
                    <div class="value-card text-center">
                        <div class="value-icon">🌿</div>
                        <h4>Экологичность</h4>
                        <p>Мы используем экологически чистые материалы и поддерживаем устойчивое развитие</p>
                    </div>
                </div>
                <div class="col">
                    <div class="value-card text-center">
                        <div class="value-icon">✨</div>
                        <h4>Качество</h4>
                        <p>Каждое изделие проходит строгий контроль качества</p>
                    </div>
                </div>
                <div class="col">
                    <div class="value-card text-center">
                        <div class="value-icon">🎨</div>
                        <h4>Уникальность</h4>
                        <p>Создаем неповторимые дизайны для ярких личностей</p>
                    </div>
                </div>
                <div class="col">
                    <div class="value-card text-center">
                        <div class="value-icon">♻️</div>
                        <h4>Ответственность</h4>
                        <p>Заботимся об окружающей среде и социальной справедливости</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="team-section">
            <h3 class="text-center mb-3">Наша Команда</h3>
            <div class="team-grid row g-4">
                <div class="col-md-6 d-flex justify-content-start">
                    <div class="team-card align-self-start">
                        <h4>Мигов Даниил Вячеславович</h4>
                        <p class="team-role">Главный дизайнер</p>
                    </div>
                </div>
                <div class="col-md-6 d-flex justify-content-end">
                    <div class="team-card align-self-end">
                        <h4>Янг Александр Кунович</h4>
                        <p class="team-role">Креативный директор</p>
                    </div>
                </div>
            </div>
        </section>
    </section>
</div>