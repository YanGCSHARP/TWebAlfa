@model  eUseControl.Domain.Models.Product

@{
    ViewBag.Title = "Детали товара";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-color: #2a2a2a;
        --accent-color: #ff4d4d;
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .product-gallery {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        transition: var(--transition);
    }

    .product-gallery:hover {
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
    }

    .main-image {
        height: 600px;
        object-fit: cover;
        cursor: zoom-in;
        transition: transform 0.3s ease;
    }

    .product-title {
        font-family: 'Roboto Condensed', sans-serif;
        font-size: 2.8rem;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin-bottom: 1.5rem;
    }

    .price-block {
        background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
        padding: 1.5rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .price {
        font-size: 2.4rem;
        color: var(--accent-color);
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .stock-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 15px;
        border-radius: 25px;
        font-size: 0.9rem;
        background: rgba(40, 167, 69, 0.15);
        color: #28a745;
    }

    .action-buttons .btn {
        font-size: 1.1rem;
        padding: 1rem 2rem;
        border-radius: 15px;
        transition: var(--transition);
    }

    .quantity-input {
        border: 2px solid var(--primary-color);
        border-radius: 12px;
        width: 100px;
        text-align: center;
        font-weight: 600;
    }

    .specs-list dt {
        font-weight: 600;
        color: var(--primary-color);
        width: 160px;
    }

    .specs-list dd {
        border-left: 3px solid var(--accent-color);
        padding-left: 1rem;
        margin-left: 0;
    }

    .zoom-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.9);
        z-index: 999;
        display: none;
        cursor: zoom-out;
    }

    .zoom-image {
        max-width: 90%;
        max-height: 90%;
        margin: auto;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    @@media (max-width: 768px) {
        .product-title {
            font-size: 2rem;
        }
        .main-image {
            height: 400px;
        }
    }
</style>

<div class="container py-5">
    <div class="row g-5">
        <!-- Изображение товара -->
        <div class="col-lg-7">
            <div class="product-gallery">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Url.Content(Model.ImageUrl)"
                         class="main-image w-100"
                         alt="@Model.Name"
                         data-action="zoom">
                }
                else
                {
                    <div class="main-image bg-light d-flex align-items-center justify-content-center">
                        <i class="fas fa-image fa-4x text-muted"></i>
                    </div>
                }
            </div>
        </div>

        <!-- Информация о товаре -->
        <div class="col-lg-5">
            <div class="product-header mb-4">
                <h1 class="product-title">@Model.Name</h1>
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="price-block">
                        <div class="price">
                            @Model.Price.ToString("N2") $
                            <span class="text-muted fs-6">вкл. НДС</span>
                        </div>
                    </div>
                    <div class="stock-badge">
                        <i class="fas fa-@(Model.Stock > 0 ? "check" : "times") me-2"></i>
                        @(Model.Stock > 0 ? "В наличии" : "Нет в наличии")
                    </div>
                </div>
            </div>

            <!-- Кнопки действий -->
            <div class="action-buttons mb-5">
                @using (Html.BeginForm("AddToCart", "Cart", FormMethod.Post, new { @class = "mb-3" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("productId", Model.Id)

                    <div class="d-flex gap-2 align-items-stretch">
                        <input type="number"
                               name="quantity"
                               value="1"
                               min="1"
                               class="form-control quantity-input"
                               style="height: auto">
                        <button type="submit"
                                class="btn btn-danger flex-grow-1"
                                @(Model.Stock == 0 ? "disabled" : "")>
                            <i class="fas fa-shopping-cart me-2"></i>Добавить в корзину
                        </button>
                    </div>
                }

                @using (Html.BeginForm("InstantCheckout", "Order", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("productId", Model.Id)
                    @Html.Hidden("quantity", 1)

                    <button type="submit"
                            class="btn btn-dark w-100"
                            @(Model.Stock == 0 ? "disabled" : "")>
                        <i class="fas fa-bolt me-2"></i>Быстрый заказ
                    </button>
                }
            </div>

            <!-- Описание и характеристики -->
            <div class="product-details">
                <div class="mb-5">
                    <h4 class="mb-3"><i class="fas fa-align-left me-2"></i>Описание</h4>
                    <p class="text-secondary lead">@Model.Description</p>
                </div>

                <div class="specs-section">
                    <h4 class="mb-4"><i class="fas fa-list-alt me-2"></i>Характеристики</h4>
                    <dl class="specs-list">
                        <div class="d-flex mb-3">
                            <dt>Категория</dt>
                            <dd>@(Model.Category?.Name ?? "Не указана")</dd>
                        </div>
                        <div class="d-flex mb-3">
                            <dt>Артикул</dt>
                            <dd>#@Model.Id</dd>
                        </div>
                        <div class="d-flex mb-3">
                            <dt>Доступность</dt>
                            <dd>
                                @if (Model.Stock > 0)
                                {
                                    <span class="text-success fw-bold">@Model.Stock шт. на складе</span>
                                }
                                else
                                {
                                    <span class="text-danger">Под заказ</span>
                                }
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Zoom Overlay -->
<div class="zoom-overlay">
    <img src="" class="zoom-image">
</div>

<script>
    // Обработка увеличения изображения
    document.querySelectorAll('[data-action="zoom"]').forEach(img => {
        img.addEventListener('click', function() {
            const overlay = document.querySelector('.zoom-overlay');
            const zoomImg = overlay.querySelector('.zoom-image');
            zoomImg.src = this.src;
            overlay.style.display = 'block';
        });
    });

    document.querySelector('.zoom-overlay').addEventListener('click', function() {
        this.style.display = 'none';
    });
</script>