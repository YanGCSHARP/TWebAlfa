@model object
@{
    ViewBag.Title = "О нас - LNP Fashion Demon";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <!-- Секция "Герой" -->
    <section class="info-hero mb-5">
        <div class="info-hero-content text-center text-white">
            <h1 class="golden-text mb-4">Наша История</h1>
            <p class="lead fs-3">С 2025 года мы создаем уникальную моду для уникальных людей</p>
        </div>
    </section>

    <!-- Секция "Миссия" -->
    <section class="mission-section py-5 bg-light">
        <div class="container">
            <h2 class="text-center mb-5">Наша Миссия</h2>
            <p class="text-center fs-5 mx-auto" style="max-width: 800px;">
                LNP Fashion Demon - это не просто бренд одежды. Это образ жизни, философия и стремление к совершенству в каждой детали.
            </p>

            <!-- Статистика -->
            <div class="row justify-content-center g-4 mt-5">
                <div class="col-lg-3 col-md-6 text-center">
                    <div class="stat-item p-3">
                        <div class="stat-number display-6 fw-bold text-danger">5000+</div>
                        <div class="stat-label fs-5">Довольных клиентов</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 text-center">
                    <div class="stat-item p-3">
                        <div class="stat-number display-6 fw-bold text-danger">300+</div>
                        <div class="stat-label fs-5">Уникальных моделей</div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 text-center">
                    <div class="stat-item p-3">
                        <div class="stat-number display-6 fw-bold text-danger">15</div>
                        <div class="stat-label fs-5">Городов присутствия</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Секция "Ценности" -->
    <section class="values-section py-5">
        <div class="container">
            <h2 class="text-center mb-5">Наши Ценности</h2>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                <div class="col">
                    <div class="value-card h-100 p-4 text-center shadow-sm">
                        <div class="value-icon fs-1 mb-3">🌿</div>
                        <h4>Экологичность</h4>
                        <p class="mb-0">Мы используем экологически чистые материалы и поддерживаем устойчивое развитие</p>
                    </div>
                </div>
                <div class="col">
                    <div class="value-card h-100 p-4 text-center shadow-sm">
                        <div class="value-icon fs-1 mb-3">✨</div>
                        <h4>Качество</h4>
                        <p class="mb-0">Каждое изделие проходит строгий контроль качества</p>
                    </div>
                </div>
                <div class="col">
                    <div class="value-card h-100 p-4 text-center shadow-sm">
                        <div class="value-icon fs-1 mb-3">🎨</div>
                        <h4>Уникальность</h4>
                        <p class="mb-0">Создаем неповторимые дизайны для ярких личностей</p>
                    </div>
                </div>
                <div class="col">
                    <div class="value-card h-100 p-4 text-center shadow-sm">
                        <div class="value-icon fs-1 mb-3">♻️</div>
                        <h4>Ответственность</h4>
                        <p class="mb-0">Заботимся об окружающей среде и социальной справедливости</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Секция "Команда" -->
    <section class="team-section py-5 bg-light">
        <div class="container">
            <h2 class="text-center mb-5">Наша Команда</h2>
            <div class="row g-4 justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <div class="team-card p-4 bg-white rounded shadow-sm">
                        <h4 class="mb-3">Мигов Даниил Вячеславович</h4>
                        <p class="team-role text-muted mb-0">Главный дизайнер</p>
                    </div>
                </div>
                <div class="col-md-8 col-lg-6">
                    <div class="team-card p-4 bg-white rounded shadow-sm">
                        <h4 class="mb-3">Янг Александр Кунович</h4>
                        <p class="team-role text-muted mb-0">Креативный директор</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>